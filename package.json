{
  "name": "vscode-pptx-viewer",
  "displayName": "PPTX Viewer",
  "description": "View PowerPoint (.pptx, .ppsx, .pptm, .ppsm, .potx, .potm) presentations directly in VS Code",
  "version": "0.0.12",
  "publisher": "astx-jp",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "assets/icon.png",
  "homepage": "https://github.com/astx-jp/vscode-pptx-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/astx-jp/vscode-pptx-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/astx-jp/vscode-pptx-viewer/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "pptx",
    "ppsx",
    "pptm",
    "ppsm",
    "potx",
    "potm",
    "powerpoint",
    "slides",
    "viewer"
  ],
  "activationEvents": [],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "pptxViewer.preview",
        "displayName": "PPTX Viewer",
        "selector": [
          {
            "filenamePattern": "*.pptx"
          },
          {
            "filenamePattern": "*.ppsx"
          },
          {
            "filenamePattern": "*.pptm"
          },
          {
            "filenamePattern": "*.ppsm"
          },
          {
            "filenamePattern": "*.potx"
          },
          {
            "filenamePattern": "*.potm"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "package": "node esbuild.mjs --production",
    "vscode:prepublish": "npm run package",
    "dump-slide": "node dist/dump-slide.mjs",
    "screenshot": "PLAYWRIGHT_BROWSERS_PATH=/tmp/claude/pw-browsers node dist/dump-slide.mjs",
    "slide:measure": "node tools/measure-slide-dom.mjs",
    "slide:diff": "node tools/pixel-diff.mjs",
    "evidence": "node dist/evidence-baseline.mjs",
    "evidence:slide": "node tools/commit-visual-probe.mjs",
    "evidence:capture": "node dist/evidence-baseline.mjs capture",
    "evidence:diff": "node dist/evidence-baseline.mjs diff",
    "evidence:summary": "node dist/evidence-baseline.mjs summary",
    "test": "npm run test:unit && npm run test:vitest",
    "test:unit": "node tools/run-parser-unit-tests.mjs",
    "test:vitest": "vitest run",
    "audit:high": "npm audit --audit-level=high",
    "test:tools": "node --test tools/verify-release.test.mjs && node tools/run-parser-unit-tests.mjs",
    "test:pw:redraw": "node --test tools/playwright-tab-redraw.test.mjs",
    "test:pw:spautofit": "node --test tools/playwright-spautofit.test.mjs",
    "lint:md": "markdownlint-cli2",
    "lint:md:all": "markdownlint-cli2 \"**/*.md\"",
    "verify-release": "node tools/verify-release.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "markdownlint-cli2": "0.21.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "emf-converter": "^1.0.7",
    "fast-xml-parser": "^4.5.6",
    "jszip": "^3.10.1",
    "sharp": "^0.34.5"
  }
}
